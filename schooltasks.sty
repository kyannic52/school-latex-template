% schooltasks.sty
% Aufgaben mit Metadaten: Schwierigkeit, Typisierung, Punkte, Tags.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{schooltasks}[2026/06/30 Task environments]

\RequirePackage{xkeyval}
\RequirePackage{tcolorbox}
\RequirePackage{xcolor}
\RequirePackage{tikz}
\RequirePackage{etoolbox}
\tcbuselibrary{skins,breakable}

\newcounter{schooltask}
\newcounter{schoolsubtask}[schooltask]
\renewcommand{\theschoolsubtask}{\alph{schoolsubtask}}

\def\taskDifficulty{}
\def\taskType{}
\def\taskPoints{}
\def\taskTag{}
\def\taskTitle{}

\define@key{taskmeta}{difficulty}{\def\taskDifficulty{#1}}
\define@key{taskmeta}{type}{\def\taskType{#1}}
\define@key{taskmeta}{points}{\def\taskPoints{#1}}
\define@key{taskmeta}{tag}{\def\taskTag{#1}}
\define@key{taskmeta}{title}{\def\taskTitle{#1}}

\newcommand{\difficultyDots}[1]{%
\ifstrequal{#1}{1}{●○○}{}%
\ifstrequal{#1}{2}{●●○}{}%
\ifstrequal{#1}{3}{●●●}{}%
\ifstrequal{#1}{easy}{●○○}{}%
\ifstrequal{#1}{medium}{●●○}{}%
\ifstrequal{#1}{hard}{●●●}{}%
}

\newcommand{\taskTypeBadge}[1]{%
  \tikz[baseline=(x.base)]\node[rounded corners=3pt,fill=schoolSoft,draw=schoolLine,inner xsep=5pt,inner ysep=2pt](x){\sffamily\scriptsize\ttfamily #1};%
}

\newcommand{\taskMetaLine}{%
  \ifx\taskDifficulty\empty\else\textcolor{schoolMuted}{Niveau }\textcolor{schoolPrimary}{\difficultyDots{\taskDifficulty}}\quad\fi
  \ifx\taskType\empty\else\textcolor{schoolMuted}{Typ }\taskTypeBadge{\taskType}\quad\fi
  \ifx\taskTag\empty\else\textcolor{schoolMuted}{#}\texttt{\taskTag}\quad\fi
  \ifx\taskPoints\empty\else\hfill\tikz[baseline=(p.base)]\node[rounded corners=4pt,fill=schoolPrimary,text=white,inner xsep=6pt,inner ysep=2.2pt](p){\sffamily\bfseries\small \taskPoints{} P};\fi
}

\newenvironment{task}[1][]{%
  \stepcounter{schooltask}%
  \setcounter{schoolsubtask}{0}%
  \setkeys{taskmeta}{difficulty={},type={},points={},tag={},title={},#1}%
  \begin{tcolorbox}[enhanced,breakable,arc=4mm,boxrule=.7pt,colback=white,colframe=schoolLine,
    borderline west={2.4pt}{0pt}{schoolPrimary},left=4mm,right=4mm,top=3mm,bottom=3mm]
  {\sffamily\bfseries\color{schoolInk}Aufgabe \theschooltask\ifx\taskTitle\empty\else{} · \taskTitle\fi}\par
  {\sffamily\small\taskMetaLine}\par\vspace{1mm}
}{%
  \end{tcolorbox}
}

\newcommand{\subtask}[2][]{%
  \stepcounter{schoolsubtask}%
  \par\smallskip\noindent\textbf{\theschoolsubtask)}\quad #2%
  \ifstrempty{#1}{}{\hfill\textcolor{schoolMuted}{#1 P}}%
  \par
}

\newenvironment{solution}{%
\begin{tcolorbox}[enhanced,breakable,arc=3mm,boxrule=.5pt,colback=schoolSoftBlue,colframe=schoolSecondary,title=Lösungsskizze,fonttitle=\bfseries]
}{\end{tcolorbox}}
