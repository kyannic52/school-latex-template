% schooltasks.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{schooltasks}[2026/06/30 Task environments for school templates]

\RequirePackage{pgfkeys}
\RequirePackage{xparse}
\RequirePackage{needspace}
\RequirePackage{schooldesign}

\newcounter{schooltask}
\newif\ifschoolshowtaskmeta
\schoolshowtaskmetafalse

\newcommand\schooltaskdifficulty{}
\newcommand\schooltasktype{}
\newcommand\schooltaskpoints{}
\newcommand\schooltasktag{}
\newcommand\schooltasktitle{}

\pgfkeys{
  /school/task/.is family, /school/task,
  title/.store in=\schooltasktitle,
  difficulty/.store in=\schooltaskdifficulty,
  type/.store in=\schooltasktype,
  points/.store in=\schooltaskpoints,
  tag/.store in=\schooltasktag,
  title=,
  difficulty=,
  type=,
  points=,
  tag=
}

\newcommand{\taskMetaLine}{%
  \ifschoolshowtaskmeta
    \par\vspace{.8mm}{\scriptsize\color{schoolMuted}%
      \ifx\schooltaskdifficulty\empty\else Schwierigkeit: \schooltaskdifficulty\quad\fi
      \ifx\schooltasktype\empty\else Typ: \schooltasktype\quad\fi
      \ifx\schooltaskpoints\empty\else Punkte: \schooltaskpoints\quad\fi
      \ifx\schooltasktag\empty\else Tag: \schooltasktag\fi
    }%
  \fi
}

\NewDocumentEnvironment{task}{O{}}{%
  \refstepcounter{schooltask}%
  \pgfkeys{/school/task, title=, difficulty=, type=, points=, tag=, #1}%
  \Needspace{3.5cm}%
  \par\vspace{4mm}%
  \noindent{\color{schoolPrimary}\rule{\linewidth}{0.7pt}}\par\vspace{2.5mm}%
  \noindent\begin{minipage}[c]{8mm}\centering\schoolNumberBadge{\arabic{schooltask}}\end{minipage}%
  \hspace{2mm}%
  \begin{minipage}[c]{\dimexpr\linewidth-10mm\relax}%
    {\large\bfseries\color{schoolInk}\schooltasktitle}%
    \taskMetaLine\par\smallskip
}{%
  \end{minipage}\par\vspace{1mm}%
}

\NewDocumentCommand{\subtask}{O{} m}{%
  \par\smallskip\noindent\textbf{#1}\quad #2\par\smallskip
}

\endinput
