% schooldesign.sty
% Gemeinsames Design fuer schulische Materialien.
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{schooldesign}[2026/06/30 Modern school material design]

\RequirePackage{xcolor}
\RequirePackage{xkeyval}
\RequirePackage{geometry}
\RequirePackage{fontspec}
\RequirePackage{tikz}
\RequirePackage{tcolorbox}
\RequirePackage{fancyhdr}
\RequirePackage{lastpage}
\RequirePackage{enumitem}
\RequirePackage{tabularx}
\RequirePackage{etoolbox}
\RequirePackage{titlesec}
\RequirePackage{graphicx}
\RequirePackage{iftex}

\usetikzlibrary{calc,positioning,shapes.geometric}
\tcbuselibrary{skins,breakable}

% Basisschrift: modern, aber mit Fallback.
\defaultfontfeatures{Ligatures=TeX}
\IfFontExistsTF{Inter}{\setmainfont{Inter}}{\setmainfont{Latin Modern Sans}}
\IfFontExistsTF{Inter}{\setsansfont{Inter}}{\setsansfont{Latin Modern Sans}}

% Standardfarben. Themes duerfen diese Werte ueberschreiben.
\definecolor{schoolPrimary}{HTML}{0EA5A8}
\definecolor{schoolSecondary}{HTML}{2563EB}
\definecolor{schoolAccent}{HTML}{14B8A6}
\definecolor{schoolInk}{HTML}{172033}
\definecolor{schoolMuted}{HTML}{64748B}
\definecolor{schoolLine}{HTML}{D8E3EA}
\definecolor{schoolSoft}{HTML}{EEF8FB}
\definecolor{schoolSoftBlue}{HTML}{EFF6FF}
\definecolor{schoolSoftGreen}{HTML}{ECFDF5}
\definecolor{schoolWarning}{HTML}{F59E0B}
\definecolor{schoolSuccess}{HTML}{10B981}
\definecolor{schoolDanger}{HTML}{EF4444}

\geometry{a4paper,left=18mm,right=18mm,top=18mm,bottom=21mm,headheight=26pt}
\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}
\fancyfoot[C]{\sffamily\small\color{schoolMuted}Seite \thepage{} von \pageref{LastPage}}

\setlength{\parindent}{0pt}
\setlength{\parskip}{6pt}
\setlist[itemize]{leftmargin=*,itemsep=2pt,topsep=2pt}
\setlist[enumerate]{leftmargin=*,itemsep=2pt,topsep=2pt}

\titleformat{\section}{\sffamily\Large\bfseries\color{schoolInk}}{}{0pt}{}
\titleformat{\subsection}{\sffamily\large\bfseries\color{schoolInk}}{}{0pt}{}

% Globale Metadaten
\newcommand{\schoolTitle}{Arbeitsblatt}
\newcommand{\schoolSubtitle}{}
\newcommand{\schoolSubject}{Mathematik}
\newcommand{\schoolGrade}{}
\newcommand{\schoolClass}{}
\newcommand{\schoolDate}{\today}
\newcommand{\schoolTeacher}{}
\newcommand{\schoolNumber}{}
\newcommand{\schoolNameField}{Name}
\newcommand{\schoolTime}{}

\newcommand{\worksheetsetup}[1]{\setkeys{schoolmeta}{#1}}
\define@key{schoolmeta}{title}{\renewcommand{\schoolTitle}{#1}}
\define@key{schoolmeta}{subtitle}{\renewcommand{\schoolSubtitle}{#1}}
\define@key{schoolmeta}{subject}{\renewcommand{\schoolSubject}{#1}}
\define@key{schoolmeta}{grade}{\renewcommand{\schoolGrade}{#1}}
\define@key{schoolmeta}{class}{\renewcommand{\schoolClass}{#1}}
\define@key{schoolmeta}{date}{\renewcommand{\schoolDate}{#1}}
\define@key{schoolmeta}{teacher}{\renewcommand{\schoolTeacher}{#1}}
\define@key{schoolmeta}{number}{\renewcommand{\schoolNumber}{#1}}
\define@key{schoolmeta}{namefield}{\renewcommand{\schoolNameField}{#1}}
\define@key{schoolmeta}{time}{\renewcommand{\schoolTime}{#1}}

\newcommand{\schoolpill}[1]{%
  \tikz[baseline=(x.base)]\node[rounded corners=5pt,fill=schoolSoft,draw=schoolLine,inner xsep=7pt,inner ysep=3pt](x){\sffamily\small\color{schoolInk}#1};%
}

\newcommand{\schoolIconCircle}[1]{%
  \tikz[baseline=(c.base)]\node[circle,fill=schoolPrimary,text=white,inner sep=3.2pt](c){\sffamily\bfseries\scriptsize #1};%
}

\newcommand{\schoolHeader}{%
\begin{tikzpicture}[remember picture,overlay]
  \fill[schoolSoftBlue] (current page.north west) rectangle ([yshift=-30mm]current page.north east);
  \fill[schoolPrimary] ([xshift=0mm,yshift=-30mm]current page.north west) rectangle ([xshift=10mm]current page.north west);
  \fill[schoolAccent,opacity=.18] ([xshift=-18mm,yshift=-7mm]current page.north east) circle (26mm);
  \fill[schoolSecondary,opacity=.10] ([xshift=-46mm,yshift=-28mm]current page.north east) circle (13mm);
\end{tikzpicture}%
\vspace*{-3mm}
\begin{minipage}[t]{0.68\textwidth}
  {\sffamily\bfseries\Huge\color{schoolInk}\schoolTitle\par}
  \ifx\schoolSubtitle\empty\else{\sffamily\large\color{schoolMuted}\schoolSubtitle\par}\fi
\end{minipage}\hfill
\begin{minipage}[t]{0.28\textwidth}\raggedleft
  \schoolpill{\schoolSubject\ifx\schoolGrade\empty\else{} · Kl. \schoolGrade\fi}\par\vspace{1.5mm}
  \ifx\schoolNumber\empty\else\schoolpill{Nr. \schoolNumber}\fi
\end{minipage}
\par\vspace{8mm}
}

\newcommand{\schoolInfoBar}{%
\begin{tcolorbox}[enhanced,arc=3mm,boxrule=.6pt,colback=white,colframe=schoolLine,left=3mm,right=3mm,top=2.2mm,bottom=2.2mm]
\begin{tabularx}{\textwidth}{@{}>{\sffamily\color{schoolMuted}}l X >{\sffamily\color{schoolMuted}}l X >{\sffamily\color{schoolMuted}}l X@{}}
\schoolNameField: & \hrulefill & Klasse: & \schoolClass & Datum: & \schoolDate
\end{tabularx}
\end{tcolorbox}
}

\newenvironment{infobox}[1][Info]{%
\begin{tcolorbox}[enhanced,breakable,arc=4mm,boxrule=.6pt,colback=schoolSoftBlue,colframe=schoolSecondary,left=4mm,right=4mm,top=3mm,bottom=3mm,
  title={\schoolIconCircle{i}\hspace{1.5mm}#1},fonttitle=\sffamily\bfseries\color{schoolInk},coltitle=schoolInk]
}{\end{tcolorbox}}

\newenvironment{notebox}[1][Hinweis]{%
\begin{tcolorbox}[enhanced,breakable,arc=4mm,boxrule=.6pt,colback=schoolSoftGreen,colframe=schoolAccent,left=4mm,right=4mm,top=3mm,bottom=3mm,
  title={\schoolIconCircle{!}\hspace{1.5mm}#1},fonttitle=\sffamily\bfseries\color{schoolInk},coltitle=schoolInk]
}{\end{tcolorbox}}

\newenvironment{definitionbox}[1][Merke]{%
\begin{tcolorbox}[enhanced,breakable,arc=4mm,boxrule=.6pt,colback=schoolSoft,colframe=schoolPrimary,left=4mm,right=4mm,top=3mm,bottom=3mm,
  title={\schoolIconCircle{M}\hspace{1.5mm}#1},fonttitle=\sffamily\bfseries\color{schoolInk},coltitle=schoolInk]
}{\end{tcolorbox}}

\newcommand{\answerlines}[1][3]{%
  \par\vspace{1mm}\foreach \n in {1,...,#1}{\noindent\color{schoolLine}\rule{\linewidth}{0.4pt}\par\vspace{6mm}}\color{black}%
}
