% schooldesign.sty
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{schooldesign}[2026/06/30 Design helpers for school templates]

\RequirePackage{tikz}
\RequirePackage{tcolorbox}
\tcbuselibrary{skins,breakable}
\RequirePackage{fontawesome5}
\RequirePackage{tabularx}
\RequirePackage{array}
\RequirePackage{ifthen}

\newlength\schoolIconSize
\setlength\schoolIconSize{20mm}

% Großer Fach-Icon-Kasten im Kopf, bewusst ohne externe Bilddateien.
\newcommand{\schoolSubjectIcon}{%
  \begin{tikzpicture}[baseline=(box.base)]
    \node[rounded corners=3mm, minimum width=\schoolIconSize, minimum height=\schoolIconSize,
      inner sep=0pt, shade, left color=schoolPrimaryDark, right color=schoolAccent] (box) {};
    \begin{scope}[scale=1.38]
      \draw[white, line width=.75pt, -stealth] (-.38,-.28) -- (-.38,.34);
      \draw[white, line width=.75pt, -stealth] (-.42,-.28) -- (.38,-.28);
      \draw[white, line width=.8pt] (-.32,-.18) -- (-.12,.06) -- (.05,-.05) -- (.32,.28);
      \fill[white] (-.32,-.18) circle (0.7pt) (-.12,.06) circle (0.7pt) (.05,-.05) circle (0.7pt) (.32,.28) circle (0.7pt);
    \end{scope}
  \end{tikzpicture}%
}

\newcommand{\schoolNumberBadge}[1]{%
  \tikz[baseline=(n.base)]\node[rounded corners=1.3mm, minimum width=7.5mm, minimum height=7.5mm,
    inner sep=0pt, shade, left color=schoolPrimaryDark, right color=schoolAccent,
    text=white, font=\bfseries\small] (n) {#1};%
}

\newcommand{\schoolSmallPill}[1]{%
  \tikz[baseline=(p.base)]\node[rounded corners=1.6mm, fill=schoolSoft, draw=schoolLine,
    inner xsep=2.4mm, inner ysep=.8mm, text=schoolInk, font=\scriptsize\bfseries] (p) {#1};%
}

\newcommand{\schoolInfoLine}[2]{%
  \noindent\textcolor{schoolMuted}{#1}\hspace{1.5mm}\textbf{#2}\par
}

\newtcolorbox{schoolSoftBox}[2][]{
  enhanced,
  breakable,
  colback=schoolSoftBlue,
  colframe=schoolSoftBlue,
  boxrule=0pt,
  arc=3mm,
  left=4mm,right=4mm,top=3mm,bottom=3mm,
  title={#2},
  fonttitle=\bfseries\color{schoolInk},
  coltitle=schoolInk,
  attach title to upper={\par\smallskip},
  #1
}

\newenvironment{rememberbox}[1][Merke dir]{%
  \begin{schoolSoftBox}{\faLightbulb[regular]\hspace{2mm}#1}%
}{\end{schoolSoftBox}}

\newenvironment{tipbox}[1][Tipp]{%
  \begin{schoolSoftBox}[colback=schoolSoft,colframe=schoolSoft]{\faBrain\hspace{2mm}#1}%
}{\end{schoolSoftBox}}

\newenvironment{notebox}[1][Notizen]{%
  \begin{schoolSoftBox}[colback=white,colframe=schoolLine,boxrule=.4pt]{\faPen\hspace{2mm}#1}%
}{\end{schoolSoftBox}}

\newcommand{\answerline}[1][4cm]{\rule{#1}{0.35pt}}
\newcommand{\writinglines}[2][8mm]{\par\vspace{1mm}\foreach \i in {1,...,#2}{\noindent\rule{\linewidth}{0.25pt}\par\vspace{#1}}}
\newcommand{\gridbox}[2][12]{%
  \begin{tikzpicture}
    \draw[step=4mm, schoolLine, very thin] (0,0) grid (#1*4mm,#2*4mm);
  \end{tikzpicture}%
}

\endinput
